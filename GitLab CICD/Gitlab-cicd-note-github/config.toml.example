[[runners]]
  name = "lndata-2-docker"
  url = "https://gitlab.com"
  id = 53274226
  token = "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
  token_obtained_at = 2026-05-21T04:09:38Z
  token_expires_at = 0001-01-01T00:00:00Z
  executor = "docker"
  [runners.cache]
    MaxUploadedArchiveSize = 0
    [runners.cache.s3]
      AssumeRoleMaxConcurrency = 0
    [runners.cache.gcs]
    [runners.cache.azure]
  [runners.docker]
    tls_verify = false
    image = "docker:24"
    privileged = true
    disable_entrypoint_overwrite = false
    oom_kill_disable = false
    disable_cache = false
    volumes = ["/certs/client","/srv/gitlab-runner-docker-executor-cache:/cache"]
    volume_keep = false
    shm_size = 268435456
    pull_policy = ["if-not-present", "always"]
    network_mtu = 0
